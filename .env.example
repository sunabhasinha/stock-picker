# Copy to .env (gitignored) and fill in real values YOURSELF - do not paste
# real values into any agent chat. Load with: set -a; source .env; set +a
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.evovlpmbvtshemuwdaoo.supabase.co:5432/postgres
ANTHROPIC_API_KEY=

# M2 auth server (uvicorn app.server:app --port 8000)
APP_BASE_URL=http://127.0.0.1:8000
# Set to 1 in ANY deployment (adds Secure to the session cookie).
# Off by default only because local dev runs plain http.
APP_COOKIE_SECURE=0
# Optional: real Postgres for the RLS-layer test (tests/test_auth.py) -
# point at the same DB as DATABASE_URL or a scratch one.
# TEST_DATABASE_URL=
